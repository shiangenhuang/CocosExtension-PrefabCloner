{
    "package_version": 2,
    "version": "1.1.0",
    "name": "prefab-cloner",
    "title": "Prefab Cloner & Script Scanner",
    "description": "Clone prefab across bundles with UUID regeneration & scan scenes for missing script references",
    "main": "./dist/main.js",
    "devDependencies": {
        "@types/node": "^16.0.1",
        "typescript": "^4.3.4"
    },
    "author": "PartyGo",
    "editor": ">=3.8.1",
    "scripts": {
        "build": "tsc -b",
        "watch": "tsc -w",
        "test": "node dist/test-scan.js",
        "scan": "node dist/cli-scan.js",
        "scan:test": "node dist/cli-scan.js D:/Github_igs/partygo-client/assets/games/newbiePractice/scene/test.scene D:/Github_igs/partygo-client/assets/games/newbiePractice D:/Github_igs/partygo-client"
    },
    "contributions": {
        "menu": [
            {
                "path": "Prefab Cloner",
                "label": "Clone Prefab to Folder",
                "message": "clone-prefab"
            },
            {
                "path": "Prefab Cloner",
                "label": "Scan Scene/Prefab Scripts",
                "message": "scan-scene"
            },
            {
                "path": "Prefab Cloner",
                "label": "Scan Entire Bundle Scripts",
                "message": "scan-bundle"
            }
        ],
        "messages": {
            "clone-prefab": {
                "methods": [
                    "clonePrefab"
                ]
            },
            "scan-scene": {
                "methods": [
                    "scanScene"
                ]
            },
            "scan-bundle": {
                "methods": [
                    "scanBundle"
                ]
            }
        }
    }
}
